    "pulled_date": "2026-04-16",
    "notes": "Structural token patterns not covered by main default_patterns.json or S3-A/B/C proposals",
    "xor_key": "0x5A",
    "skipped": [
      "pkcs12-file: file-type detection, not applicable",
      "kubernetes-secret-yaml: K8s YAML parsing, not applicable",
      "curl-auth-header: curl command parsing, not applicable",
      "curl-auth-user: curl command parsing, not applicable",
      "freemius-secret-key: capturing group on PHP string context, not a structural token",
      "jwt-base64: extremely long named-group regex, RE2 incompatible, covered by jwt_token",
      "nuget-config-password: XML config file pattern, not applicable",
      "sidekiq-secret: bundle URL credential, niche",
      "sidekiq-sensitive-url: bundle URL, niche",
      "hashicorp-tf-password: generic password variable, too broad",
      "lob-api-key: context-only pattern (live_/test_ keywords too generic)",
      "lob-pub-api-key: context-only pattern (_pub keyword too generic)",
      "gitter-access-token: context-only, provider keyword only",
      "azure-ad-client-secret: Q~ pattern too short (6 chars), high FP risk \u2014 promoted to keyword",
      "aws-amazon-bedrock-api-key-short-lived: base64-literal prefix pattern, not regex-stable",
      "clickhouse-cloud-api-secret-key: 4b1d prefix only 4 chars, high FP risk",
      "sentry-org-token: complex named-group regex, simplified to keyword",
      "gitlab-rrt: GR1348941 prefix is 9 chars + 20 \u2014 added to gitlab_token_extended",
      "intra42-client-secret: niche provider, covered by keyword",
      "harness-api-key: pat./sat. prefix too generic \u2014 promoted to keyword"
    ]
  },
