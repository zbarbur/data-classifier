+# ── Test: Sprint 9 fastino config defaults ─────────────────────────────────
+
+
+class TestFastinoDefaults:
+    """Test the Sprint 9 GLiNER tuning defaults."""
+
+    def test_default_model_is_fastino(self):
+        """Default ``_MODEL_ID`` should be the fastino v2 model."""
+        from data_classifier.engines.gliner_engine import _MODEL_ID
+
+        assert _MODEL_ID == "fastino/gliner2-base-v1"
+
+    def test_default_threshold_is_eighty(self):
+        """Default confidence threshold should be 0.80 for fastino."""
+        from data_classifier.engines.gliner_engine import _DEFAULT_GLINER_THRESHOLD
+
+        assert _DEFAULT_GLINER_THRESHOLD == 0.80
+
+    def test_ssn_label_is_social_security_number(self):
+        """SSN gliner label should be 'social security number' (Sprint 9 swap)."""
+        from data_classifier.engines.gliner_engine import ENTITY_LABEL_DESCRIPTIONS
+
+        assert ENTITY_LABEL_DESCRIPTIONS["SSN"][0] == "social security number"
+
+    def test_person_name_label_is_full_name(self):
+        """PERSON_NAME gliner label should be 'full name' (Sprint 9 swap)."""
+        from data_classifier.engines.gliner_engine import ENTITY_LABEL_DESCRIPTIONS
+
+        assert ENTITY_LABEL_DESCRIPTIONS["PERSON_NAME"][0] == "full name"
+
+    def test_fastino_defaults_descriptions_off(self):
+        """fastino model should default to descriptions_enabled=False."""
+        from data_classifier.engines.gliner_engine import GLiNER2Engine
+
+        engine = GLiNER2Engine(model_id="fastino/gliner2-base-v1")
+        assert engine._is_v2 is True
+        assert engine._descriptions_enabled is False
+
+    def test_v1_model_defaults_descriptions_on(self):
+        """v1 (non-fastino) model should default to descriptions_enabled=True.
+
+        v1 ignores the flag at inference time (it only accepts a label list),
+        but the flag is still set for consistency.
+        """
+        from data_classifier.engines.gliner_engine import GLiNER2Engine
+
+        engine = GLiNER2Engine(model_id="urchade/gliner_multi_pii-v1")
+        assert engine._is_v2 is False
+        assert engine._descriptions_enabled is True
+
+    def test_descriptions_enabled_override(self):
+        """Caller can force descriptions on for fastino if needed."""
+        from data_classifier.engines.gliner_engine import GLiNER2Engine
+
+        engine = GLiNER2Engine(model_id="fastino/gliner2-base-v1", descriptions_enabled=True)
+        assert engine._descriptions_enabled is True
+
+
+class TestFastinoV2InferencePath:
+    """Test the v2 ``extract_entities`` inference codepath (fastino)."""
+
+    def _make_v2_engine(self, mock_registry, mock_model, *, descriptions_enabled: bool | None = None):
+        from data_classifier.engines.gliner_engine import GLiNER2Engine
+
+        engine = GLiNER2Engine(
+            registry=mock_registry,
+            model_id="fastino/gliner2-base-v1",
+            descriptions_enabled=descriptions_enabled,
+        )
+        mock_registry.register(
+            "gliner2-ner",
+            loader=lambda: mock_model,
+            model_class="gliner2.GLiNER2",
+            requires=[],
+        )
+        engine._registered = True
+        return engine
+
+    def test_v2_descriptions_off_passes_label_list(self, mock_registry):
+        """When descriptions_enabled=False, engine should pass a list[str]
+        (no descriptions) to ``extract_entities`` and include the
+        configured threshold."""
+        mock_model = MagicMock()
+        mock_model.extract_entities = MagicMock(
+            return_value={"entities": {"full name": [{"text": "Jane Doe", "confidence": 0.91}]}}
+        )
+        engine = self._make_v2_engine(mock_registry, mock_model)
+
+        column = ColumnInput(column_name="name", column_id="c1", sample_values=["Jane Doe"])
+        findings = engine.classify_column(column, min_confidence=0.0)
+
+        assert len(findings) == 1
+        assert findings[0].entity_type == "PERSON_NAME"
+
+        # Verify call shape: positional entity_spec was a list[str].
+        assert mock_model.extract_entities.called
+        call_args = mock_model.extract_entities.call_args
+        entity_spec = call_args.args[1] if len(call_args.args) > 1 else call_args.kwargs.get("entity_types")
+        assert isinstance(entity_spec, list), f"Expected list[str] label spec, got {type(entity_spec).__name__}"
+        assert "full name" in entity_spec
+        assert "social security number" in entity_spec
+        # Threshold must be passed through (Sprint 9: 0.80 default).
+        assert call_args.kwargs.get("threshold") == 0.80
+
+    def test_v2_descriptions_on_passes_label_dict(self, mock_registry):
+        """When descriptions_enabled=True, engine should pass a dict[str, str]."""
+        mock_model = MagicMock()
+        mock_model.extract_entities = MagicMock(return_value={"entities": {}})
+        engine = self._make_v2_engine(mock_registry, mock_model, descriptions_enabled=True)
+
+        column = ColumnInput(column_name="x", column_id="c1", sample_values=["something"])
+        engine.classify_column(column, min_confidence=0.0)
+
+        call_args = mock_model.extract_entities.call_args
+        entity_spec = call_args.args[1] if len(call_args.args) > 1 else call_args.kwargs.get("entity_types")
+        assert isinstance(entity_spec, dict), f"Expected dict[str, str] label spec, got {type(entity_spec).__name__}"
+        assert "full name" in entity_spec
+        # Descriptions must be non-empty in the dict form.
+        assert entity_spec["full name"]
