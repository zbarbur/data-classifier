{
  "_metadata": {
    "version": "0.1.0",
    "description": "Curated content-matching patterns for PII, financial, credential, and health data detection. RE2-compatible.",
    "pattern_count": 44,
    "last_updated": "2026-04-10",
    "coverage_notes": "Iteration 1: core PII + financial + credential patterns. Benchmarked against Presidio, gitleaks, trufflehog. Service-specific API key patterns from gitleaks audit."
  },
  "patterns": [
    {
      "name": "us_ssn_formatted",
      "regex": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "entity_type": "SSN",
      "category": "PII",
      "sensitivity": "CRITICAL",
      "confidence": 0.95,
      "description": "US Social Security Number in XXX-XX-XXXX format",
      "validator": "ssn_zeros",
      "examples_match": [
        "123-45-6789",
        "987-65-4321"
      ],
      "examples_no_match": [
        "12-345-6789",
        "1234-5-6789",
        "abc-de-fghi"
      ]
    },
    {
      "name": "us_ssn_no_dashes",
      "regex": "\\b\\d{9}\\b",
      "entity_type": "SSN",
      "category": "PII",
      "sensitivity": "CRITICAL",
      "confidence": 0.4,
      "description": "9-digit number that could be an SSN without dashes. Low confidence \u2014 many false positives.",
      "validator": "ssn_zeros",
      "examples_match": [
        "123456789"
      ],
      "examples_no_match": [
        "12345678",
        "1234567890",
        "abcdefghi"
      ]
    },
    {
      "name": "credit_card_visa",
      "regex": "\\b4\\d{12}(?:\\d{3})?\\b",
      "entity_type": "CREDIT_CARD",
      "category": "Financial",
      "sensitivity": "CRITICAL",
      "confidence": 0.9,
      "description": "Visa card number (starts with 4, 13 or 16 digits)",
      "validator": "luhn",
      "examples_match": [
        "4111111111111111",
        "4012888888881881"
      ],
      "examples_no_match": [
        "5111111111111111",
        "411111111111111",
        "41111111111111111"
      ]
    },
    {
