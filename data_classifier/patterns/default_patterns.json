      "regex": "\\b\\d{4}[- ]\\d{4}[- ]\\d{4}[- ]\\d{4}\\b",
      "entity_type": "CREDIT_CARD",
      "category": "Financial",
      "sensitivity": "CRITICAL",
      "confidence": 0.85,
      "description": "Credit card with separators (XXXX-XXXX-XXXX-XXXX)",
      "validator": "luhn_strip",
      "examples_match": [
        "4111-1111-1111-1111",
        "4111 1111 1111 1111"
